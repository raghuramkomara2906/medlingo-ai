# MedLingo Translator Environment Variables

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
EXPO_PUBLIC_API_KEY=your-api-key-here

# Development
NODE_ENV=development

# Backend Configuration (for your backend server)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
DATABASE_URL=postgresql://username:password@localhost:5432/medlingo

# External Services
TRANSLATION_API_KEY=your-translation-service-key
SPEECH_API_KEY=your-speech-service-key
EMAIL_SERVICE_API_KEY=your-email-service-key

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:19006,http://localhost:3000

